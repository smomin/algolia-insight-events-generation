# ─────────────────────────────────────────────
# Encryption (required)
# ─────────────────────────────────────────────
# Derives the AES-256-GCM key used to encrypt API credentials at rest.
# Use any strong, random string (min 32 chars recommended).
# WARNING: changing this invalidates all previously-stored DB credentials.
ENCRYPTION_SECRET=change-me-to-a-strong-random-secret-string

# ─────────────────────────────────────────────
# Couchbase Server (required)
# ─────────────────────────────────────────────
# Start locally:
#   docker run -d --name couchbase-algolia \
#     -p 8091-8097:8091-8097 -p 11210:11210 \
#     couchbase:community
#
# Open http://localhost:8091, complete the Setup Wizard, then fill in below.
# All industries, index names, and personas are managed via the in-app UI
# and stored in Couchbase — no index-specific env vars are needed.
COUCHBASE_URL=couchbase://localhost
COUCHBASE_USERNAME=Administrator
COUCHBASE_PASSWORD=password
COUCHBASE_BUCKET=algolia-insights

# ─────────────────────────────────────────────
# API Credentials (optional — env fallback)
# ─────────────────────────────────────────────
# Preferred: enter these in the in-app ⚙ App Settings panel.
# They will be encrypted and saved to Couchbase.
# These env vars are used as a fallback if no DB credentials are configured,
# and can be overridden per-industry from the Industry Editor.
#
# NEXT_PUBLIC_ALGOLIA_APP_ID=your_app_id
# NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=your_search_key
# ANTHROPIC_API_KEY=your_anthropic_key

# ─────────────────────────────────────────────
# Scheduler
# ─────────────────────────────────────────────
SCHEDULER_TIMEZONE=America/Los_Angeles
SCHEDULER_CRON=0 6 * * *
# Must mirror SCHEDULER_CRON so the UI displays the correct schedule.
NEXT_PUBLIC_SCHEDULER_CRON=0 6 * * *

# ─────────────────────────────────────────────
# Limits
# ─────────────────────────────────────────────
# Daily event limit per index, per industry (applied independently)
DAILY_EVENT_LIMIT_PER_INDEX=1000
NEXT_PUBLIC_DAILY_EVENT_LIMIT=1000

# Events sent per persona session
EVENTS_PER_SESSION=7

# ─────────────────────────────────────────────
# Defaults
# ─────────────────────────────────────────────
# The industry that is selected on first load and used as the API fallback
# when no industryId is supplied in the request body / query string.
DEFAULT_INDUSTRY_ID=grocery
NEXT_PUBLIC_DEFAULT_INDUSTRY_ID=grocery

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
# Controls log verbosity. Levels: debug | info | warn | error
# Only messages at or above the configured level are emitted. Defaults to "info".
# LOG_LEVEL applies server-side; NEXT_PUBLIC_LOG_LEVEL applies client-side.
LOG_LEVEL=info
NEXT_PUBLIC_LOG_LEVEL=info

# ─────────────────────────────────────────────
# External services
# ─────────────────────────────────────────────
# Algolia Insights ingest endpoint. Override to use a proxy or regional URL.
ALGOLIA_INSIGHTS_URL=https://insights.algolia.io/1/events

# Anthropic model used for query & persona generation.
ANTHROPIC_MODEL=claude-sonnet-4-5
